# ============================================
# Multi-Signature Wallet System — Environment Variables
# Copy to .env and fill in your values
# ============================================

# App
APP_NAME=Multisig Wallet Management System
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/multisig_wallet

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (REQUIRED — change these!)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Default Admin (first run only)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=

# HD Wallet
HD_MNEMONIC=
HD_MNEMONIC_ENCRYPTED=
HD_ENCRYPTION_KEY=

# Blockchain RPC
BSC_RPC_URL=https://bsc-dataseed.binance.org
TRON_RPC_URL=https://api.trongrid.io

# Alchemy (BSC)
ALCHEMY_API_KEY=

# WalletConnect
WALLETCONNECT_PROJECT_ID=

# Telegram Bot (notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
